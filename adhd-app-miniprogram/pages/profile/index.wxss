.profile-card {
  padding: 32rpx;
  background: linear-gradient(150deg, #ffffff, #e8fffb);
}

.profile-card__title {
  font-size: 40rpx;
  font-weight: 700;
}

.profile-card__subtitle,
.profile-card__stars {
  margin-top: 14rpx;
  color: #6f6b66;
  font-size: 26rpx;
}

.profile-section {
  margin-top: 24rpx;
  padding: 28rpx;
}

.profile-section.mint {
  background: #effcfb;
}
